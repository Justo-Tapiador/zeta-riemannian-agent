# zeta-riemannian-agent v1.0 — environment variables template
# Copy this file to .env and fill in the keys you want to enable.

# ─── Database ───────────────────────────────────────────────────────────
# SQLite database URL. The database file is created automatically by Prisma.
# Path is relative to the project root.
DATABASE_URL="file:./prisma/db/custom.db"

# ─── LLM providers (all optional — ZAI is auto-available) ──────────────
# The agent's primary LLM is Z.ai's GLM-4.6, exposed through the
# z-ai-web-dev-sdk. In the standard sandbox environment no key is needed.
# Add any of the following keys to enable additional providers in the
# multi-LLM router's failover chain.
#
# Failover order:
#   1. ZAI / GLM-4.6           (primary)
#   2. Groq / Llama 3.3 70B    (first fallback — requires GROQ_API_KEY)
#   3. Deterministic stub      (last resort)

# Groq (Llama 3.3 70B Versatile) — first fallback in the failover chain.
# Get a key at: https://console.groq.com/keys
# GROQ_API_KEY="gsk_..."
# Optional: override the default model (e.g. llama-3.1-8b-instant for cheap
# fast summarisation, or mixtral-8x7b-32768 for long context).
# GROQ_MODEL="llama-3.3-70b-versatile"

# OpenAI (GPT-4o) — listed in the providers panel, not yet wired into call()
# OPENAI_API_KEY="sk-..."

# Anthropic (Claude Opus 4.1) — listed in the providers panel, not yet wired into call()
# ANTHROPIC_API_KEY="sk-ant-..."

# Google (Gemini 2.0 Pro) — listed in the providers panel, not yet wired into call()
# GOOGLE_API_KEY="AIza..."

# DeepSeek (R1 / Reasoner) — listed in the providers panel, not yet wired into call()
# DEEPSEEK_API_KEY="sk-..."

# Direct ZAI HTTP mode (only needed if ZAI.create() cannot find .z-ai-config)
# ZAI_API_KEY="..."
# ZAI_BASE_URL="https://api.z.ai/api/paas/v4"

# Local Ollama (plugged in via the router; not used by default)
# OLLAMA_BASE_URL="http://localhost:11434"

# ─── Agent runtime ──────────────────────────────────────────────────────
# The WebSocket mini-service runs on port 3003 by convention.
# Do NOT change this unless you also update the Caddyfile.
AGENT_RUNTIME_PORT=3003

# Cycle interval in milliseconds (default: 60000 = 1 minute)
CYCLE_INTERVAL_MS=60000

# Run a Riemann attempt every N cycles (default: 5)
RIEMANN_EVERY_N_CYCLES=5

# Confidence threshold to declare RH proven (default: 0.90)
RH_PROMOTION_THRESHOLD=0.90

# Confidence threshold to promote a hypothesis to a theorem (default: 0.75)
PROMOTION_THRESHOLD=0.75
