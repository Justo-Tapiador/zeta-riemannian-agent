{
  "name": "zeta-riemannian-agent",
  "version": "1.0.1",
  "description": "zeta-riemannian-agent (:zRiemannian) v1.0 — Autonomous Mathematical Research Agent for the Riemann Hypothesis. Built on the Artificial Junky Neuron (AJN) framework, extended from quantum-spherifier by Justo Tapiador Garcia (UA). Generates LaTeX/PDF mathematical documents (hypotheses, proofs, theorems, periodic Riemann-attempts), organises them hierarchically, and enters RIEMANN-PROVEN MODE if the central conjecture is ever verifier-accepted.",
  "files": [
    "src/lib/",
    "web/server.js",
    "web/public/index.html",
    "web/public/css/",
    "web/public/js/",
    "web/public/zr-1-small.png",
    "web/public/zr-2-small.png",
    "prisma/schema.prisma",
    "!prisma/db/",
    "scripts/supervise-agent.sh",
    "scripts/supervise-web.sh",
    "mini-services/agent-runtime/",
    "docs/architecture.md",
